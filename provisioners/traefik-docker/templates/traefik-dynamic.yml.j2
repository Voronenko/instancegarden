# TLS configuration
tls:
  certificates:
    - certFile: /etc/traefik/certs/fiksim_fullchain.pem
      keyFile: /etc/traefik/certs/fiksim_privkey.pem
      stores:
        - default
  stores:
    default:
      defaultCertificate:
        certFile: /etc/traefik/certs/fiksim_fullchain.pem
        keyFile: /etc/traefik/certs/fiksim_privkey.pem
  options:
    default:
      minVersion: "VersionTLS12"
    modern:
      minVersion: "VersionTLS12"
      cipherSuites:
        - "TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384"
        - "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"
        - "TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256"
        - "TLS_ECDHE_RSA_WITH_AES_128_GCM_SHA256"
        - "TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305"
        - "TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305"
      sniStrict: true
      curvePreferences:
        - "CurveP521"
        - "CurveP384"
        - "CurveP256"
