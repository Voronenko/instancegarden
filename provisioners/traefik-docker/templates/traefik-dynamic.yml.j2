# Traefik Dynamic Configuration
http:
  middlewares:
    # Global HTTPS redirect middleware - excludes ACME challenges
    global-https-redirect:
      redirectScheme:
        scheme: https
        permanent: true
      # Only redirect if not ACME challenge path
      # This is handled by the acme-global router having higher priority

    # Security headers middleware
    security-headers:
      headers:
        browserXSSFilter: true
        contentTypeNosniff: true
        forceSTSHeader: {{ traefik_force_sts_header | default(false) }}
        frameDeny: true
        stsIncludeSubdomains: true
        stsPreload: true
        stsSeconds: 31536000
        referrerPolicy: "strict-origin-when-cross-origin"
        customRequestHeaders:
          X-Forwarded-Proto: "https"

    # HTTPS redirect middleware (for specific routers)
    https-redirect:
      redirectScheme:
        scheme: https
        permanent: true

    # Rate limiting middleware
    rate-limit:
      rateLimit:
        average: 100
        burst: 200

    # Compression middleware
    compression:
      compress:
        excludedContentTypes:
          - text/event-stream
          - application/grpc

  # Default router for unmatched requests
